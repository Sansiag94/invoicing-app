generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(uuid()) @map("uuid")
  email                String     @unique
  name                 String
  appLanguage          String     @default("en")
  acceptedPrivacyAt    DateTime?
  acceptedTermsAt      DateTime?
  acceptedLegalVersion String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  businesses           Business[]
}

model Business {
  id             String    @id @default(uuid()) @map("uuid")
  userId         String
  name           String
  planTier       String    @default("free")
  ownerName      String?
  invoiceSenderType String @default("company")
  address        String
  street         String?
  postalCode     String?
  city           String?
  phone          String?
  email          String?
  website        String?
  bankName       String?
  bic            String?
  country        String
  currency       String
  vatRegistered  Boolean   @default(false)
  vatNumber      String?
  iban           String?
  logoUrl        String?
  stripeCustomerId String? @unique
  stripeSubscriptionId String? @unique
  stripeSubscriptionStatus String?
  stripePriceId String?
  subscriptionCurrentPeriodEnd DateTime?
  usesPlatformStripe Boolean @default(false)
  stripeAccountId String?
  stripeChargesEnabled Boolean @default(false)
  stripePayoutsEnabled Boolean @default(false)
  stripeDetailsSubmitted Boolean @default(false)
  acceptsTwintPayments Boolean @default(false)
  twintPhoneNumber String?
  supportAssistantEnabled Boolean @default(false)
  replyToEmail String?
  defaultPaymentTermDays Int @default(30)
  defaultInvoiceMessage String?
  defaultInvoiceAttachmentUrl String?
  defaultInvoiceAttachmentName String?
  invoicePrefix  String
  invoiceCounter Int       @default(0)
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients        Client[]  @relation("BusinessClients")
  invoices       Invoice[] @relation("BusinessInvoices")
  expenses       Expense[] @relation("BusinessExpenses")
  portfolioItems PortfolioItem[] @relation("BusinessPortfolioItems")
  monthlyReports MonthlyReport[] @relation("BusinessMonthlyReports")
  unbilledWorkItems UnbilledWorkItem[] @relation("BusinessUnbilledWorkItems")
}

model Client {
  id          String    @id @default(uuid()) @map("uuid")
  businessId  String
  business    Business  @relation("BusinessClients", fields: [businessId], references: [id], onDelete: Cascade)
  companyName String?   // Optional: For companies
  contactName String?   // Optional: For individual contacts
  email       String
  phone       String?
  address     String
  street      String?
  postalCode  String?
  city        String?
  country     String
  language    String    @default("en")
  vatNumber   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  invoices    Invoice[] @relation("ClientInvoices")
  unbilledWorkItems UnbilledWorkItem[] @relation("ClientUnbilledWorkItems")

  @@index([businessId, email])
}

model Invoice {
  id            String        @id @default(uuid()) @map("uuid")
  businessId    String
  clientId      String
  invoiceNumber String
  subject       String?
  reference     String?
  status        InvoiceStatus
  issuedAt      DateTime?
  issueDate     DateTime
  dueDate       DateTime
  currency      String
  subtotal      Float
  taxAmount     Float
  totalAmount   Float
  discountType  String        @default("none")
  discountValue Float         @default(0)
  notes         String?
  paymentNote   String?
  publicToken   String?
  stripeCheckoutSessionId String?
  stripeCheckoutSessionExpiresAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  business      Business      @relation("BusinessInvoices", fields: [businessId], references: [id], onDelete: Cascade)
  client        Client        @relation("ClientInvoices", fields: [clientId], references: [id], onDelete: Cascade)
  lineItems     LineItem[]    @relation("InvoiceLineItems")
  payments      Payment[]     @relation("InvoicePayments")
  reminders     InvoiceReminder[] @relation("InvoiceReminders")
  events        InvoiceEvent[] @relation("InvoiceEvents")
  attachments   InvoiceAttachment[] @relation("InvoiceAttachments")
  unbilledWorkItems UnbilledWorkItem[] @relation("InvoiceUnbilledWorkItems")

  @@index([stripeCheckoutSessionId])
  @@index([businessId, issuedAt])
  @@index([businessId, createdAt])
  @@index([businessId, status, dueDate])
  @@index([businessId, status, issueDate])
}

model LineItem {
  id          String   @id @default(uuid()) @map("uuid")
  invoiceId   String
  position    Int      @default(0)
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float
  discountType String   @default("none")
  discountValue Float   @default(0)
  total       Float
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation("InvoiceLineItems", fields: [invoiceId], references: [id], onDelete: Cascade)
}

model InvoiceAttachment {
  id          String   @id @default(uuid()) @map("uuid")
  invoiceId   String
  businessId  String
  filename    String
  contentType String
  sizeBytes   Int
  storageBucket String
  storagePath String
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation("InvoiceAttachments", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
  @@index([businessId])
}

model Payment {
  id        String          @id @default(uuid()) @map("uuid")
  invoiceId String
  provider  PaymentProvider
  amount    Float
  currency  String
  status    String
  reference String?
  createdAt DateTime        @default(now())
  invoice   Invoice         @relation("InvoicePayments", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
}

model PortfolioItem {
  id              String   @id @default(uuid()) @map("uuid")
  businessId      String
  name            String
  description     String
  unitPrice       Float
  defaultQuantity Float    @default(1)
  taxRate         Float    @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation("BusinessPortfolioItems", fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, active])
  @@index([businessId, name])
}

model UnbilledWorkItem {
  id          String             @id @default(uuid()) @map("uuid")
  businessId  String
  clientId    String
  invoiceId   String?
  serviceDate DateTime
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float              @default(0)
  notes       String?
  status      UnbilledWorkStatus @default(unbilled)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  business    Business           @relation("BusinessUnbilledWorkItems", fields: [businessId], references: [id], onDelete: Cascade)
  client      Client             @relation("ClientUnbilledWorkItems", fields: [clientId], references: [id], onDelete: Cascade)
  invoice     Invoice?           @relation("InvoiceUnbilledWorkItems", fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([businessId, clientId, status, serviceDate])
  @@index([invoiceId])
}

model InvoiceReminder {
  id        String              @id @default(uuid()) @map("uuid")
  invoiceId String
  type      InvoiceReminderType
  sentAt    DateTime            @default(now())
  invoice   Invoice             @relation("InvoiceReminders", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, type])
  @@index([type, sentAt])
}

model InvoiceEvent {
  id        String   @id @default(uuid()) @map("uuid")
  invoiceId String
  type      String
  actor     String?
  details   String?
  createdAt DateTime @default(now())
  invoice   Invoice  @relation("InvoiceEvents", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
}

model RateLimitBucket {
  id         String   @id @default(uuid()) @map("uuid")
  route      String
  identifier String
  windowStart DateTime
  count      Int      @default(1)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([route, identifier, windowStart])
  @@index([expiresAt])
}

model Expense {
  id          String          @id @default(uuid()) @map("uuid")
  businessId  String
  vendor      String?
  description String
  category    ExpenseCategory
  otherCategoryName String?
  amount      Float
  currency    String
  expenseDate DateTime
  notes       String?
  receiptUrl  String?
  isRecurring Boolean         @default(false)
  taxDeductible Boolean       @default(true)
  vatReclaimable Boolean      @default(false)
  vatAmount   Float?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  business    Business        @relation("BusinessExpenses", fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, expenseDate])
  @@index([businessId, category])
}

model MonthlyReport {
  id              String   @id @default(uuid()) @map("uuid")
  businessId      String
  month           String
  currency        String
  metrics         Json
  emailStatus     String   @default("pending")
  emailSentAt     DateTime?
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation("BusinessMonthlyReports", fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, month])
  @@index([businessId, generatedAt])
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

enum PaymentProvider {
  stripe
  bank_transfer
}

enum InvoiceReminderType {
  before_due_3_days
  after_due_7_days
}

enum UnbilledWorkStatus {
  unbilled
  added_to_draft
  invoiced
}

enum ExpenseCategory {
  software
  office
  travel
  equipment
  tax
  subcontractor
  marketing
  meals
  education
  other
}
