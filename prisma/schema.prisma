generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(uuid()) @map("uuid")
  email      String     @unique
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businesses Business[]
}

model Business {
  id             String    @id @default(uuid()) @map("uuid")
  userId         String
  name           String
  ownerName      String?
  invoiceSenderType String @default("company")
  address        String
  street         String?
  postalCode     String?
  city           String?
  phone          String?
  email          String?
  website        String?
  bankName       String?
  country        String
  currency       String
  vatNumber      String?
  iban           String?
  logoUrl        String?
  invoicePrefix  String
  invoiceCounter Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
  clients        Client[]  @relation("BusinessClients")
  invoices       Invoice[] @relation("BusinessInvoices")
}

model Client {
  id          String    @id @default(uuid()) @map("uuid")
  businessId  String
  business    Business  @relation("BusinessClients", fields: [businessId], references: [id], onDelete: Cascade)
  companyName String?   // Optional: For companies
  contactName String?   // Optional: For individual contacts
  email       String
  phone       String?
  address     String
  street      String?
  postalCode  String?
  city        String?
  country     String
  vatNumber   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  invoices    Invoice[] @relation("ClientInvoices")
}

model Invoice {
  id            String        @id @default(uuid()) @map("uuid")
  businessId    String
  clientId      String
  invoiceNumber String
  subject       String?
  reference     String?
  status        InvoiceStatus
  issueDate     DateTime
  dueDate       DateTime
  currency      String
  subtotal      Float
  taxAmount     Float
  totalAmount   Float
  notes         String?
  publicToken   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  business      Business      @relation("BusinessInvoices", fields: [businessId], references: [id], onDelete: Cascade)
  client        Client        @relation("ClientInvoices", fields: [clientId], references: [id], onDelete: Cascade)
  lineItems     LineItem[]    @relation("InvoiceLineItems")
  payments      Payment[]     @relation("InvoicePayments")
  reminders     InvoiceReminder[] @relation("InvoiceReminders")
  events        InvoiceEvent[] @relation("InvoiceEvents")
}

model LineItem {
  id          String   @id @default(uuid()) @map("uuid")
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float
  total       Float
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation("InvoiceLineItems", fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String          @id @default(uuid()) @map("uuid")
  invoiceId String
  provider  PaymentProvider
  amount    Float
  currency  String
  status    String
  reference String?
  createdAt DateTime        @default(now())
  invoice   Invoice         @relation("InvoicePayments", fields: [invoiceId], references: [id], onDelete: Cascade)
}

model InvoiceReminder {
  id        String              @id @default(uuid()) @map("uuid")
  invoiceId String
  type      InvoiceReminderType
  sentAt    DateTime            @default(now())
  invoice   Invoice             @relation("InvoiceReminders", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, type])
  @@index([type, sentAt])
}

model InvoiceEvent {
  id        String   @id @default(uuid()) @map("uuid")
  invoiceId String
  type      String
  actor     String?
  details   String?
  createdAt DateTime @default(now())
  invoice   Invoice  @relation("InvoiceEvents", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
}

enum PaymentProvider {
  stripe
  bank_transfer
}

enum InvoiceReminderType {
  before_due_3_days
  after_due_7_days
}
